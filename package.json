{
  "name": "mcp-weather",
  "version": "1.0.0",
  "description": "Korean weather + air quality MCP server (KMA short-term forecast + AirKorea PM) over stdio.",
  "type": "module",
  "bin": { "mcp-weather": "dist/index.js" },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --test",
    "example": "node examples/weather-example.mjs"
